# HTTP port for the Express API (default in code: 3001)
PORT=3001

# PostgreSQL — matches docker-compose.yml by default
DATABASE_URL="postgresql://marketplace:marketplace@localhost:5432/marketplace"

# Comma-separated origins allowed by CORS (Next.js dev). If unset: permissive outside production.
CORS_ORIGIN="http://localhost:3000"

# HS256 signing key for POST /auth/login (required in production: at least 32 characters)
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# JWT lifetime passed to jose (default in code: 7d). Examples: 1h, 24h, 7d
# JWT_EXPIRES_IN=7d

# --- Local file uploads (product images) ---
# Absolute or relative path where uploaded files are stored (writable by the API process).
# Docker Compose mounts the host folder to /data/uploads — use that path in the container.
UPLOAD_DIR="../../data/uploads"
# Base URL (no trailing slash) prefixed to each stored file path; must be reachable from the browser.
# Typically your public API origin + "/uploads" when Express serves files at GET /uploads/* .
# On the VM, GitHub Actions deploy sets repo-root `.env` PUBLIC_UPLOAD_URL_BASE (derived from WEB_NEXT_PUBLIC_API_URL); docker-compose injects it into the API container.
PUBLIC_UPLOAD_URL_BASE="http://localhost:3001/uploads"
