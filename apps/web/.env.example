# Base URL of the Express API (exposed to the browser — must start with NEXT_PUBLIC_)
# NEXT_PUBLIC_API_URL="http://localhost:3001"

# Server-only override for `app/api/auth/login` when it must reach the API on a different host than the browser (e.g. Docker service name). Falls back to NEXT_PUBLIC_API_URL.
# API_BASE_URL="http://api:3001"

# Origin of this Next app (used by `webApiClient` only during SSR). Browser uses relative URLs. Default: http://localhost:3000
# NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

# Docker: same value is passed as a build-arg in docker-compose.yml (NEXT_PUBLIC_* is baked in at build time).

# Optional: override Next.js dev server port
# PORT=3000
