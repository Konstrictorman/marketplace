// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (PostgreSQL native enums) ---

enum ProductCondition {
  new
  used

  @@map("product_condition")
}

enum ProductStatus {
  active
  inactive
  removed

  @@map("product_status")
}

enum OrderStatus {
  pending
  confirmed
  delivered
  cancelled

  @@map("order_status")
}

enum NotificationStatus {
  pending
  sent
  failed

  @@map("notification_status")
}

enum ReportStatus {
  open
  under_review
  resolved
  dismissed

  @@map("report_status")
}

enum ReportTargetType {
  user
  product
  conversation
  message

  @@map("report_target_type")
}

// --- Core auth & profiles ---

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  surname    String
  phone      String?
  photoUrl   String?  @map("photo_url")
  reputation Decimal  @default(0) @db.Decimal(5, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  roles                   UserRole[]
  productsSold          Product[]              @relation("SellerProducts")
  ordersAsBuyer         Order[]                @relation("BuyerOrders")
  orderItemsAsSeller    OrderItem[]            @relation("SellerOrderItems")
  conversationParticipants ConversationParticipant[]
  messagesSent          Message[]
  reviewsWritten        Review[]               @relation("ReviewerReviews")
  reviewsReceived       Review[]               @relation("ReviewedUserReviews")
  notifications         Notification[]
  reportsFiled          Report[]               @relation("ReporterReports")
  reportsAgainst        Report[]               @relation("TargetUserReports")
  reportsReviewed       Report[]               @relation("ReviewedByReports")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// --- Catalog ---

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Product {
  id          String           @id @default(uuid())
  sellerId    String           @map("seller_id")
  categoryId  String           @map("category_id")
  title       String
  description String           @db.Text
  price       Decimal          @db.Decimal(12, 2)
  condition   ProductCondition
  inventory   Int              @default(0)
  status      ProductStatus    @default(active)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  seller        User              @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  category      Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images        ProductImage[]
  orderItems    OrderItem[]
  conversations Conversation[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// --- Orders ---

model Order {
  id          String      @id @default(uuid())
  buyerId     String      @map("buyer_id")
  status      OrderStatus @default(pending)
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  buyer     User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  items     OrderItem[]
  reviews   Review[]

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  productId  String   @map("product_id")
  sellerId   String   @map("seller_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  subtotal   Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller  User    @relation("SellerOrderItems", fields: [sellerId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

// --- Messaging ---

model Conversation {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  product      Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String @map("conversation_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  isRead         Boolean  @default(false) @map("is_read")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// --- Reviews ---

model Review {
  id              String   @id @default(uuid())
  reviewerId      String   @map("reviewer_id")
  reviewedUserId  String   @map("reviewed_user_id")
  orderId         String   @map("order_id")
  rating          Int
  comment         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  reviewer     User  @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedUser User  @relation("ReviewedUserReviews", fields: [reviewedUserId], references: [id], onDelete: Cascade)
  order        Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId])
  @@map("reviews")
}

// --- Notifications & moderation ---

model Notification {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  type        String
  referenceId String?             @map("reference_id")
  message     String              @db.Text
  isRead      Boolean             @default(false) @map("is_read")
  status      NotificationStatus  @default(pending)
  createdAt   DateTime            @default(now()) @map("created_at")
  readAt      DateTime?           @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Report {
  id             String            @id @default(uuid())
  reporterId     String            @map("reporter_id")
  targetUserId   String?           @map("target_user_id")
  targetType     ReportTargetType  @map("target_type")
  targetId       String            @map("target_id")
  reason         String
  description    String?           @db.Text
  status         ReportStatus      @default(open)
  createdAt      DateTime          @default(now()) @map("created_at")
  reviewedAt     DateTime?         @map("reviewed_at")
  reviewedById   String?           @map("reviewed_by_id")

  reporter   User  @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser User? @relation("TargetUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)
  reviewedBy User? @relation("ReviewedByReports", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("reports")
}
