# Optional: copy to `.env` at the repo root if you run Prisma CLI from here.
# The API normally loads `apps/api/.env` via dotenv.
DATABASE_URL="postgresql://marketplace:marketplace@localhost:5432/marketplace"

# docker-compose.yml — bind mount host path into the API container as /data/uploads.
# Local: set here. Production (GitHub Actions deploy): set repository variable
# MARKETPLACE_UPLOADS_HOST_PATH — deploy writes this file on the VM before `docker compose`.
MARKETPLACE_UPLOADS_HOST_PATH=./data/uploads

# Browser-reachable base for stored image URLs (no trailing slash). docker-compose passes this to the API container.
# Local: set explicitly. Production: deploy sets this to "${WEB_NEXT_PUBLIC_API_URL}/uploads" (see .github/workflows/deploy.yml).
PUBLIC_UPLOAD_URL_BASE=http://localhost:3001/uploads

# Next.js client → API (docker/web build arg). Set as GitHub repository variable for deploy.
# VM example: http://YOUR_PUBLIC_IP:3001
# WEB_NEXT_PUBLIC_API_URL=http://localhost:3001
